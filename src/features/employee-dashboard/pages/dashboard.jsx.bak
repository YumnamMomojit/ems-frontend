import { useState, useEffect } from "react";
import { useQuery, useMutation } from "@tanstack/react-query";
import { useNavigate } from "react-router-dom";
import { motion } from "framer-motion";
import { WelcomeBanner } from "~/features/employee-dashboard/components/welcome-banner";
import { QuickActions } from "~/features/employee-dashboard/components/quick-actions";
import { NotificationsWidget } from "~/features/employee-dashboard/components/notifications-widget";
import { TasksWidget } from "~/features/employee-dashboard/components/tasks-widget";
import { TimeTracker } from "~/features/employee-dashboard/components/time-tracker";
import { LeaveBalance } from "~/features/employee-dashboard/components/leave-balance";
import { RegularizationRequest } from "~/features/employee-dashboard/components/regularization-request";
import { useToast } from "~/hooks/use-toast";
import { queryClient } from "~/lib/queryClient";
import { Skeleton } from "~/components/employee-ui/skeleton";
import api from "../../../services/api.js";
import { Pencil, X } from "lucide-react";

export default function Dashboard() {
  const { toast } = useToast();
  const [isClockedIn, setIsClockedIn] = useState(false);
  const [clockInTime, setClockInTime] = useState(null);
  const [isRegularizationOpen, setIsRegularizationOpen] = useState(false);
  const [isCoverModalOpen, setIsCoverModalOpen] = useState(false);
  const [coverImage, setCoverImage] = useState("https://images.unsplash.com/photo-1497366216548-37526070297c?auto=format&fit=crop&q=80");

  const { data: fetchedDashboardData, isLoading } = useQuery({
    queryKey: ["/api/employee/dashboard"],
  });

  const dashboardData = fetchedDashboardData || {};

  useEffect(() => {
    if (dashboardData) {
      console.log("📊 Dashboard API data:", dashboardData);
      setIsClockedIn(dashboardData.isClockedIn);
      if (dashboardData.todayClockIn) {
        setClockInTime(dashboardData.todayClockIn);
      }
    }
  }, [dashboardData]);


  const handleCoverImageUpload = (e) => {
    const file = e.target.files[0];
    if (file) {
      const reader = new FileReader();
      reader.onloadend = () => {
        setCoverImage(reader.result);
        setIsCoverModalOpen(false);
        toast({ title: "Success", description: "Cover image updated successfully!" });
      };
      reader.readAsDataURL(file);
    }
  };

  const clockMutation = useMutation({
    mutationFn: async ({ action, location }) => {
      const response = await api.post("/attendance/clock", { action, location });
      return response.data;
    },

    onSuccess: (result) => {
      if (result.action === "in") {
        setIsClockedIn(true);
        setClockInTime(result.clockInTime);
      } else {
        setIsClockedIn(false);
        setClockInTime(null);
      }

      toast({
        title: result.action === "in" ? "Clocked In" : "Clocked Out",
        description:
          result.action === "in"
            ? `Clocked in at ${new Date(
              result.clockInTime,
            ).toLocaleTimeString()}`
            : `You worked ${result.hoursWorked} hours today`,
      });

      queryClient.invalidateQueries({ queryKey: ["/api/dashboard"] });
    },

    onError: (error) => {
      toast({
        title: "Attendance Error",
        description: error.message,
        variant: "destructive",
      });
    },
  });

  const handleClockToggle = () => {
    if (isClockedIn && !dashboardData.worksheetSubmitted) {
      toast({
        title: "Action Required",
        description: "Please submit your daily worksheet before clocking out.",
        variant: "destructive",
      });
      return;
    }

    const action = isClockedIn ? "out" : "in";

    if ("geolocation" in navigator) {
      toast({
        title: "Punching...",
        description: "Capturing your current location...",
      });

      navigator.geolocation.getCurrentPosition(
        (position) => {
          const { latitude, longitude } = position.coords;
          clockMutation.mutate({ action, location: { lat: latitude, lng: longitude } });
        },
        (error) => {
          console.error("Geolocation error:", error);
          let errorMessage = "Unable to retrieve your location. Punching in without GPS data.";

          if (error.code === error.PERMISSION_DENIED) {
            errorMessage = "Location access denied. Please enable GPS in your browser for accuracy.";
          } else if (error.code === error.TIMEOUT) {
            errorMessage = "Location request timed out. Punching in without GPS data.";
          }

          toast({
            title: "GPS Unavailable",
            description: errorMessage,
            variant: "warning",
          });

          // Proceed without location
          clockMutation.mutate({ action });
        },
        { timeout: 10000, enableHighAccuracy: true, maximumAge: 0 }
      );
    } else {
      toast({
        title: "GPS Not Supported",
        description: "Your browser does not support geolocation. Punching in without GPS data.",
        variant: "warning",
      });
      clockMutation.mutate({ action });
    }
  };

  const navigate = useNavigate();

  const handleApplyLeave = () => {
    navigate("/employee/leave");
  };

  const handleRegularize = () => {
    setIsRegularizationOpen(true);
  };

  // Mock Notifications based on pending actions or other data
  const notifications = [
    ...(dashboardData.pendingActions || []).map(action => ({
      id: action.id,
      title: "Action Required",
      message: `${action.title} requires your attention.`,
      time: action.date,
      type: "pending",
      read: false
    })),
    // Add dummy notifications if empty for demo purposes (optional)
    { id: 'mock-1', title: "Welcome!", message: "Welcome to your new dashboard.", time: "Just now", type: "info", read: false }
  ];

  // Mock Tasks (since no API yet)
  const taskList = [
    { id: 1, title: "Complete End of Month Report", progress: 75, priority: "high", dueDate: "Today", isOverdue: false },
    { id: 2, title: "Update Profile Information", progress: 30, priority: "medium", dueDate: "Tomorrow", isOverdue: false },
  ];

  if (isLoading) {
    return (
      <div className="p-6 space-y-6">
        <Skeleton className="h-32 w-full rounded-xl" />
        <div className="grid grid-cols-1 lg:grid-cols-3 gap-6">
          <Skeleton className="h-64 rounded-xl" />
          <Skeleton className="h-64 rounded-xl" />
          <Skeleton className="h-64 rounded-xl" />
        </div>
      </div>
    );
  }

  return (
    <motion.div
      initial={{ opacity: 0 }}
      animate={{ opacity: 1 }}
      transition={{ duration: 0.3 }}
      className="p-4 md:p-6 space-y-6 max-w-7xl mx-auto text-foreground"
      data-testid="dashboard-page">

      {/* Profile Header Section (From HR Template) */}
      <div className="relative w-full rounded-2xl bg-card dark:bg-card shadow-sm border border-border mb-8">
        {/* Blurred Background with overflow-visible to show popup */}
        <div className="overflow-visible rounded-t-2xl">
          <div className="h-48 w-full bg-cover bg-center relative" style={{ backgroundImage: `url('${coverImage}')` }}>
            <div className="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent backdrop-blur-[2px]"></div>

            {/* Pencil Edit Button with Popup */}
            <div className="absolute bottom-4 right-4 z-10">
              <button
                onClick={() => {
                  setIsCoverModalOpen(!isCoverModalOpen);
                }}
                className="p-2 bg-white/90 dark:bg-gray-800/90 hover:bg-white dark:hover:bg-gray-800 rounded-full shadow-lg transition-all"
                title="Edit Cover Image"
              >
                <Pencil className="h-4 w-4 text-gray-700 dark:text-gray-300" />
              </button>

              {/* Popup Menu */}
              {isCoverModalOpen && (
                <>
                  {/* Backdrop to close popup */}
                  <div
                    className="fixed inset-0 z-40"
                    onClick={() => setIsCoverModalOpen(false)}
                  ></div>

                  {/* Popup content - Dropdown below pencil */}
                  <div className="absolute top-full right-0 mt-2 bg-card dark:bg-card border border-border rounded-lg shadow-xl z-50 w-64">
                    <div className="p-3 border-b border-border">
                      <h3 className="font-semibold text-sm text-foreground">Cover photo</h3>
                    </div>
                    <div className="p-3">
                      <input
                        type="file"
                        id="coverImageInput"
                        accept="image/*"
                        onChange={handleCoverImageUpload}
                        className="hidden"
                      />
                      <label
                        htmlFor="coverImageInput"
                        className="flex items-center gap-2 px-3 py-2 text-sm text-foreground hover:bg-muted rounded-md cursor-pointer transition-colors"
                      >
                        <Pencil className="h-4 w-4" />
                        Edit image
                      </label>
                    </div>
                  </div>
                </>
              )}
            </div>
          </div>
        </div>
        <div className="px-8 pb-8 relative flex flex-col md:flex-row gap-6 items-start md:items-end -mt-12">
          {/* Avatar */}
          <div className="relative group">
            <div className="h-32 w-32 rounded-full border-4 border-background dark:border-card shadow-lg overflow-hidden bg-background">
              <img alt="Profile" className="h-full w-full object-cover" src={`https://ui-avatars.com/api/?name=${dashboardData.user?.firstName || 'User'}+${dashboardData.user?.lastName || ''}&background=random`} />
            </div>
            <div className="absolute bottom-2 right-2 h-6 w-6 bg-green-500 border-2 border-background dark:border-card rounded-full" title="Online"></div>
          </div>
          {/* Basic Info */}
          <div className="flex-1 mb-2">
            <div className="flex flex-wrap items-center gap-3 mb-1">
              <h1 className="text-3xl font-bold text-foreground dark:text-foreground">{dashboardData.user?.firstName} {dashboardData.user?.lastName}</h1>
              <span className="inline-flex items-center rounded-full bg-primary/10 px-2.5 py-0.5 text-xs font-bold text-primary ring-1 ring-inset ring-primary/20">
                {dashboardData.user?.role || 'EMPLOYEE'}
              </span>
            </div>
            <div className="flex flex-col sm:flex-row sm:items-center gap-2 sm:gap-6 text-muted-foreground dark:text-muted-foreground text-sm font-medium">
              <span className="flex items-center gap-1.5">
                <span className="material-symbols-outlined text-[18px]">work</span>
                {dashboardData.user?.designation || 'Employee'}
              </span>
              <span className="hidden sm:block text-muted-foreground/40">•</span>
              <span className="flex items-center gap-1.5">
                <span className="material-symbols-outlined text-[18px]">location_on</span>
                Corporate Office
              </span>
            </div>
          </div>
        </div>
      </div>

      <div className="grid grid-cols-1 lg:grid-cols-3 gap-6">
        {/* Left Column: Quick Actions & Time Tracker */}
        <div className="space-y-6">
          <QuickActions
            isClockedIn={isClockedIn}
            onClockToggle={handleClockToggle}
            onApplyLeave={handleApplyLeave}
            onRegularize={handleRegularize}
            worksheetSubmitted={dashboardData.worksheetSubmitted}
          />
          <TimeTracker
            weekData={dashboardData.weekData || []}
            totalWorked={
              dashboardData.weekData?.reduce((acc, d) => acc + d.worked, 0) ||
              37
            }
            totalExpected={40}
          />
        </div>

        {/* Middle Column: Tasks & Leave Balance */}
        <div className="space-y-6">
          <TasksWidget tasks={taskList} />
          <LeaveBalance
            casualLeave={
              dashboardData.leaveBalance?.casualLeave || { total: 12, used: 4 }
            }
            sickLeave={
              dashboardData.leaveBalance?.sickLeave || { total: 6, used: 1 }
            }
            privilegeLeave={
              dashboardData.leaveBalance?.privilegeLeave || {
                total: 15,
                used: 5,
              }
            }
          />
        </div>

        {/* Right Column: Notifications */}
        <div className="space-y-6">
          <NotificationsWidget notifications={notifications} />
        </div>
      </div>

      <RegularizationRequest
        isOpen={isRegularizationOpen}
        onClose={setIsRegularizationOpen}
      />
    </motion.div>
  );
}
